{
  "name": "lookml-color-formatter",
  "displayName": "lookml-color-formatter",
  "description": "LookML color formatter, syntax",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:lookml"
  ],
  "contributes": {
    "languages": [{
      "id": "lookml",
      "aliases": ["LookML", "lookml"],
      "extensions": [".lkml",".lookml"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "lookml",
      "scopeName": "source.lkml",
      "path": "./syntaxes/lookml.tmLanguage.json"
    }],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "name": "Keywords — view, dimension, measure, include, extends, type, sql, label, etc.",
            "scope": "keyword.control.lookml",
            "settings": { "foreground": "#61AFEF" }
          },
          {
            "name": "Strings — quoted values like \"Free Time Adjustment\"",
            "scope": "string.quoted.double.lookml",
            "settings": { "foreground": "#ee9977" }
          },
          {
            "name": "Interpolation — ${TABLE}, ${view_name.field}, etc.",
            "scope": "variable.interpolation.lookml",
            "settings": { "foreground": "#E06C75" }
          },
          {
            "name": "Type values — string, number, yesno, date, count, sum, etc.",
            "scope": "support.type.lookml",
            "settings": { "foreground": "#ab56cc" }
          },
          {
            "name": "SQL terminator — ;;",
            "scope": "punctuation.terminator.sql.lookml",
            "settings": { "foreground": "#9a969e" }
          },
          {
            "name": "Comments — # inline comments",
            "scope": "comment.line.number-sign.lookml",
            "settings": { "foreground": "#7F848E", "fontStyle": "italic" }
          }
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0"
  }
}