{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LookML",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#values"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#interpolation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.lookml",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lookml",
          "match": "\\b(view|explore|dimension|measure|dimension_group|sql|type|primary_key|derived_table|datagroup_trigger|bind_all_filters|hidden|label|group_label|view_label|column|field|explore_source)\\b"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.language.boolean.lookml",
          "match": "\\b(yes|no|true|false|null)\\b"
        },
        {
          "name": "constant.numeric.lookml",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.lookml",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.lookml",
          "match": "\\\\."
        },
        {
          "name": "variable.interpolation.lookml",
          "match": "\\\\\\$\\{[^}]+\\}"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "variable.interpolation.lookml",
          "match": "\\$\\{[^}]+\\}"
        }
      ]
    },
    "sql-block": {
      "name": "meta.block.sql.lookml",
      "begin": "\\b(sql)\\s*:(?!\\s*\".*\")",
      "beginCaptures": {
        "1": { "name": "keyword.control.sql.lookml" },
        "0": { "name": "punctuation.separator.key-value.lookml" }
      },
      "end": ";;",
      "endCaptures": {
        "0": { "name": "punctuation.terminator.sql.lookml" }
      },
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#strings" }
      ]
    }
  },
  "scopeName": "source.lkml"
}