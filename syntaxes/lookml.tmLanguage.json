{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LookML",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#sql-block"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#type-values"
    },
    {
      "include": "#values"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#interpolation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.lookml",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lookml",
          "match": "\\b(include|view|explore|dimension|measure|dimension_group|extends|sql|type|primary_key|derived_table|datagroup_trigger|bind_all_filters|hidden|label|group_label|view_label|column|field|explore_source|group_item_label|description|suggest_dimension|suggest_persist_for|filter|join|relationship|from|fields|fanout_on|required_joins|tags|value_format|value_format_name|drill_fields|link|url|icon_url|action|param|set|connection|all_fields)\\b"
        }
      ]
    },
    "type-values": {
      "patterns": [
        {
          "name": "support.type.lookml",
          "match": "\\b(string|number|yesno|date|date_time|time|datetime|date_raw|epoch|count|count_distinct|sum|sum_distinct|average|average_distinct|max|min|list|percent_of_previous|percent_of_total|running_total|many_to_one|many_to_many|one_to_many|one_to_one|duration_day|duration_hour|duration_minute|duration_month|duration_quarter|duration_second|duration_week|duration_year)\\b"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.language.boolean.lookml",
          "match": "\\b(yes|no|true|false|null)\\b"
        },
        {
          "name": "constant.numeric.lookml",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.lookml",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.lookml",
          "match": "\\\\."
        },
        {
          "name": "variable.interpolation.lookml",
          "match": "\\$\\{[^}]+\\}"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "variable.interpolation.lookml",
          "match": "\\$\\{[^}]+\\}"
        }
      ]
    },
    "sql-block": {
      "name": "meta.block.sql.lookml",
      "begin": "\\b(sql)\\s*:(?!\\s*\".*\")",
      "beginCaptures": {
        "1": { "name": "keyword.control.sql.lookml" },
        "0": { "name": "punctuation.separator.key-value.lookml" }
      },
      "end": ";;",
      "endCaptures": {
        "0": { "name": "punctuation.terminator.sql.lookml" }
      },
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#strings" }
      ]
    }
  },
  "scopeName": "source.lkml"
}